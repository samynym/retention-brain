{
  "name": "retention-brain",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "tsc -b",
    "retb": "tsx packages/cli/src/index.ts",
    "demo": "tsx packages/cli/src/index.ts demo",
    "start": "pnpm --filter @retention-brain/server start"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
